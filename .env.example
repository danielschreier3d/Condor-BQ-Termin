# Kopiere diese Datei zu .env (für lokales Testen).
# In GitHub Actions werden diese Werte als Repository-Secrets gesetzt.

# --- Ziel ---
TARGET_URL=https://shop.interpersonal.aero/de/BQ-ip-Ab-Initio/BQI10020

# --- E-Mail (Gmail-Beispiel) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=deinaccount@gmail.com
SMTP_PASSWORD=DEIN_16_STELLIGES_APP_PASSWORT
